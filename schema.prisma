// prisma/schema.prisma
// Supabase requires two connection URLs:
//   DATABASE_URL → Transaction pooler (port 6543) — runtime queries
//   DIRECT_URL   → Direct connection  (port 5432) — prisma migrate only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  clerkId      String    @unique
  username     String    @unique
  displayName  String?
  displayNameUpdatedAt DateTime?
  bio          String?
  avatarUrl    String?
  isAdmin      Boolean   @default(false)
  karmaPost    Int       @default(0)
  karmaComment Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  posts           Post[]
  comments        Comment[]
  votes           Vote[]
  postSaves       SavedPost[]
  memberships     CommunityMember[]
  reportsFiled    Report[] @relation("ReportsFiled")
  reportsResolved Report[] @relation("ReportsResolved")
  moderationReceived ModerationAction[] @relation("ModerationActionsReceived")
  moderationIssued   ModerationAction[] @relation("ModerationActionsIssued")
  following         UserFollow[] @relation("UserFollowing")
  followers         UserFollow[] @relation("UserFollowers")

  @@index([clerkId])
  @@index([username])
}

model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  icon        String   @default("⚡")
  color       String   @default("#5b8dee")
  isNSFW      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts   Post[]
  members CommunityMember[]

  @@index([name])
}

model CommunityMember {
  id          String   @id @default(cuid())
  userId      String
  communityId String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

enum Role {
  MEMBER
  MODERATOR
  ADMIN
}

model Post {
  id           String   @id @default(cuid())
  title        String
  body         String?
  url          String?
  imageKey     String?
  type         PostType @default(TEXT)
  flair        String?
  flairColor   String?
  score        Int      @default(0)
  commentCount Int      @default(0)
  isNSFW       Boolean  @default(false)
  isLocked     Boolean  @default(false)
  isHidden     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authorId    String
  communityId String

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  comments  Comment[]
  votes     Vote[]
  saves     SavedPost[]
  reports   Report[]

  @@index([communityId, createdAt(sort: Desc)])
  @@index([score(sort: Desc)])
  @@index([authorId])
  @@index([isHidden])
}

enum PostType {
  TEXT
  LINK
  IMAGE
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  score     Int      @default(0)
  isHidden  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  postId   String
  parentId String?

  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies Comment[] @relation("Replies")
  votes   Vote[]
  reports Report[]

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([authorId])
  @@index([isHidden])
}

model Vote {
  id        String   @id @default(cuid())
  value     Int
  createdAt DateTime @default(now())

  userId    String
  postId    String?
  commentId String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
}

model SavedPost {
  id      String   @id @default(cuid())
  userId  String
  postId  String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId, createdAt])
}

model Report {
  id          String           @id @default(cuid())
  targetType  ReportTargetType
  reason      ReportReason
  note        String?
  status      ReportStatus     @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?
  reporterId  String
  resolvedById String?
  postId      String?
  commentId   String?

  reporter   User     @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("ReportsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  post       Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([status, createdAt])
  @@index([reporterId, status])
  @@index([postId])
  @@index([commentId])
}

model ModerationAction {
  id        String               @id @default(cuid())
  type      ModerationActionType
  note      String?
  createdAt DateTime             @default(now())
  userId    String
  adminId   String
  reportId  String?

  user   User   @relation("ModerationActionsReceived", fields: [userId], references: [id], onDelete: Cascade)
  admin  User   @relation("ModerationActionsIssued", fields: [adminId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([adminId, createdAt])
  @@index([reportId])
}

enum ReportTargetType {
  POST
  COMMENT
}

enum ReportReason {
  SPAM
  HARASSMENT
  ILLEGAL
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ModerationActionType {
  NOTE
  WARNING
  HIDE_POST
  DELETE_POST
  HIDE_COMMENT
  DELETE_COMMENT
}
